{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "prepare:vad-assets": "mkdir -p public/vad && cp node_modules/@ricky0123/vad-web/dist/silero_vad_legacy.onnx public/vad/ && cp node_modules/onnxruntime-web/dist/*.wasm public/vad/ && cp node_modules/onnxruntime-web/dist/*.mjs public/vad/",
        "build": "npm run prepare:vad-assets && vite build",
        "dev": "npm run prepare:vad-assets && vite"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "@ricky0123/vad-web": "^0.0.30",
        "@vitejs/plugin-vue": "^6.0.4",
        "vue": "^3.5.30"
    }
}
