OPENAI_PROJECT=
OPENAI_PROXY=http://DbdAm6:vPd6L3@198.20.179.126:8000

# AI: провайдер по умолчанию для всех фич, если ниже не задано иное.
AI_PROVIDER=openai

# Базовые значения OpenAI для фич генерации текста.
AI_OPENAI_MODEL=gpt-5.2
AI_OPENAI_TEMPERATURE=0.1

# Настройки фичи ревью интервью.
# Провайдер для запросов ревью интервью.
AI_INTERVIEW_REVIEW_PROVIDER=openai
# Модель для оценки ответов кандидата.
AI_INTERVIEW_REVIEW_MODEL=gpt-5.2
# Уровень креативности (чем ниже, тем стабильнее и детерминированнее).
AI_INTERVIEW_REVIEW_TEMPERATURE=0.1
# Максимум токенов в ответе ревью.
AI_INTERVIEW_REVIEW_MAX_TOKENS=2500
# Язык итогового ревью (сводка и детали).
AI_INTERVIEW_REVIEW_OUTPUT_LANGUAGE=ru

# Настройки фичи генерации вопросов.
# Провайдер для AI-генерации вопросов интервью.
AI_QUESTION_GENERATION_PROVIDER=openai
# Модель для генерации вопросов интервью.
AI_QUESTION_GENERATION_MODEL=gpt-5.2
# Уровень креативности для сгенерированных вопросов.
AI_QUESTION_GENERATION_TEMPERATURE=0.2
# Максимум токенов для результата генерации вопросов.
AI_QUESTION_GENERATION_MAX_TOKENS=2000
# Язык сгенерированных вопросов.
AI_QUESTION_GENERATION_OUTPUT_LANGUAGE=ru

# Настройки фичи speech-to-text.
# Провайдер для запросов транскрибации.
AI_SPEECH_TO_TEXT_PROVIDER=openai
# Модель для распознавания речи.
AI_SPEECH_TO_TEXT_MODEL=gpt-4o-transcribe
# Температура декодирования при транскрибации.
AI_SPEECH_TO_TEXT_TEMPERATURE=0

# Настройки VAD (Voice Activity Detection) перед вызовом STT.
# Включает предварительную проверку VAD перед отправкой аудио в API транскрибации.
AI_SPEECH_TO_TEXT_VAD_ENABLED=true
# Порог тишины в dB (чем ниже значение, тем чувствительнее к тихим звукам).
AI_SPEECH_TO_TEXT_VAD_NOISE_THRESHOLD_DB=-45
# Минимальная длина сегмента тишины (в секундах) для silencedetect.
AI_SPEECH_TO_TEXT_VAD_MIN_SILENCE_SECONDS=0.2
# Минимальная обнаруженная длина речи (в секундах), чтобы запускать STT.
AI_SPEECH_TO_TEXT_VAD_MIN_SPEECH_SECONDS=0.5
# Таймаут в секундах для команды ffmpeg VAD.
AI_SPEECH_TO_TEXT_VAD_TIMEOUT_SECONDS=5
# Если true, STT все равно запускается при падении VAD (таймаут/ошибка ffmpeg).
AI_SPEECH_TO_TEXT_VAD_FAIL_OPEN=true